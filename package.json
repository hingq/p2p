{
  "name": "p2p-chat-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "lerna run dev --parallel",
    "dev:backend": "lerna run dev --scope backend",
    "dev:frontend": "lerna run dev --scope frontend",
    "build": "lerna run build",
    "build:backend": "lerna run build --scope backend",
    "build:frontend": "lerna run build --scope frontend",
    "test": "lerna run test",
    "test:backend": "lerna run test --scope backend",
    "test:frontend": "lerna run test --scope frontend"
  },
  "devDependencies": {
    "lerna": "^8.2.2",
    "npm-run-all": "^4.1.5"
  }
}
